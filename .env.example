# Pulseroom Environment Variables
# Copy this file to .env and provide real values. Never commit .env.

PORT=8888
FRONTEND_URL=http://localhost:3000
MONGODB_ATLAS_URI=mongodb://localhost/pulseroom
DEMO_MODE=false

# Required in production. Generate a long random value (at least 32 bytes).
JWT_ACCESS_SECRET=

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/api/spotify/callback

# Optional: enables Audius search.
AUDIUS_API_KEY=
