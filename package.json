{
  "name": "pulseroom",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "start": "if-env NODE_ENV=production && npm run start:prod || npm run start:dev",
    "start:prod": "node --no-deprecation server.js",
    "start:dev": "concurrently \"nodemon --ext js,json,env --ignore client server.js\" \"npm run client\"",
    "dev": "npm run start:dev",
    "client": "npm --prefix client run start",
    "install": "cd client && npm install",
    "build": "cd client && npm run build",
    "heroku-postbuild": "cd client && npm run build"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^2.0.22"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "connect-mongo": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "if-env": "^1.0.4",
    "mongoose": "^7.2.2",
    "morgan": "^1.10.0",
    "query-string": "^8.1.0",
    "serve": "^14.2.0",
    "socket.io": "^4.6.1"
  }
}
